  "keyFeatures": [
    "Transport cube lifecycle management with 4-stage workflow (Created, Sent, Downloading, Downloaded)",
    "Real-time guide tracking and validation with barcode scanning",
    "Multi-stage logistics workflows (customs dispatch, warehouse transit, reception, client dispatch)",
    "Secure authentication with token refresh and session management",
    "State-based filtering and batch operations for transport cubes",
    "Provider-based state management using Flutter Provider pattern",
    "RESTful API integration with comprehensive error handling",
    "Guide status validation by process type"
  ],
